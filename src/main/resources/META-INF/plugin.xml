<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>rs.co.bora5.plugins.BABjInteliJ</id>
    <name>BABj Support</name>
    <vendor url="https://bora5.co.rs">bora5</vendor>

    <description><![CDATA[
        Razvojna podrška za <b>babj</b> biblioteku (rs.co.bora5.programs.bab).<br>
        <ul>
          <li><b>Generator</b> — iz JPA entiteta napravi kvartet DTO / Home / View / EditWindow
              po babj konvencijama (Alt+Insert &rarr; <i>babj CRUD</i>).</li>
          <li><b>Live templates</b> — <code>bview</code>, <code>bwin</code>, <code>bhome</code>,
              <code>bdto</code>.</li>
          <li><b>Inspekcija</b> — upozorava kad GenericView nema prateći Edit&lt;Entity&gt;Window
              (sa quick-fix-om koji ga generiše).</li>
        </ul>
        ]]></description>

    <!-- Java PSI je jedina neophodna zavisnost; radi i na Community Edition. -->
    <depends>com.intellij.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <defaultLiveTemplates file="/liveTemplates/babj.xml"/>

        <localInspection language="JAVA"
                         shortName="BabjMissingEditWindow"
                         displayName="babj: GenericView bez Edit prozora"
                         groupName="babj"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="rs.co.bora5.plugins.babj.inspection.MissingEditWindowInspection"/>
    </extensions>

    <actions>
        <action id="babj.GenerateCrud"
                class="rs.co.bora5.plugins.babj.action.GenerateBabjCrudAction"
                text="babj CRUD (DTO, Home, View, Window)"
                description="Generiše babj kvartet iz izabranog JPA entiteta">
            <add-to-group group-id="GenerateGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
