<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>rs.co.bora5.plugins.BABjInteliJ</id>
    <name>BABj</name>
    <vendor url="https://bora5.co.rs">bora5</vendor>

    <description><![CDATA[
        Development support for the <b>BABj</b> library (rs.co.bora5.programs.bab).<br>
        <ul>
          <li><b>Generator</b> — creates a DTO / Home / View / EditWindow quartet from a JPA entity
              following BABj conventions (Alt+Insert &rarr; <i>BABj CRUD</i>).</li>
          <li><b>Live templates</b> — <code>bview</code>, <code>bwin</code>, <code>bhome</code>,
              <code>bdto</code>.</li>
          <li><b>Inspections</b> — validate BABj view, service, DTO, and edit-window conventions,
              with a quick fix for generating a missing Edit&lt;Entity&gt;Window.</li>
        </ul>
        ]]></description>

    <!-- Java PSI is the only dependency; the plugin runs on Community and Ultimate alike. -->
    <depends>com.intellij.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <defaultLiveTemplates file="/liveTemplates/BABj.xml"/>

        <localInspection language="JAVA"
                         shortName="BABjMissingEditWindow"
                         displayName="BABj: GenericView without an Edit window"
                         groupName="BABj"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="rs.co.bora5.plugins.babj.inspection.MissingEditWindowInspection"/>

        <localInspection language="JAVA"
                         shortName="BABjHomeSelect"
                         displayName="BABj: validate getSelect fields and getJoin aliases"
                         groupName="BABj"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="rs.co.bora5.plugins.babj.inspection.HomeSelectInspection"/>

        <localInspection language="JAVA"
                         shortName="BABjColumnNames"
                         displayName="BABj: validate @ColumnNames against entity and service DTO"
                         groupName="BABj"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="rs.co.bora5.plugins.babj.inspection.ColumnNamesInspection"/>
    </extensions>

    <actions>
        <action id="BABj.GenerateCrud"
                class="rs.co.bora5.plugins.babj.action.GenerateBABjCrudAction"
                icon="/icons/babjAction.svg"
                text="BABj CRUD (DTO, Home, View, Window)"
                description="Generates the BABj DTO, Home, View, and EditWindow from the selected JPA entity">
            <add-to-group group-id="GenerateGroup" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
